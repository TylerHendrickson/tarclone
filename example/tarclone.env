# Copy to tarclone.env and edit.
# tarclone reads its config from the environment. Load this file however you
# like, e.g. `set -a; source tarclone.env; set +a; ./tarclone.sh`, or point a
# Docker env_file / systemd EnvironmentFile at it.
#
# Secret indirection: the heartbeat ping URLs (TARCLONE_PING_URL, TARCLONE_PING_URL_START,
# TARCLONE_PING_URL_FAILURE) each also accept a <NAME>_FILE variant naming a file whose
# contents become the value (e.g. TARCLONE_PING_URL_FILE=/run/secrets/ping_url), so the
# token can come from a Docker/Kubernetes secret mount. A directly-set value
# takes precedence over its _FILE.
#
# Hint: You can run tarclone with `--show-config` to build a file like this one,
# based on your effective configuration and/or default values.

# ---- Required ----

# Directory to back up. The archive's top-level dir and filename prefix both
# derive from its basename (here, "important-stuff").
TARCLONE_SOURCE=/path/to/important-stuff

# Configured rclone remote to upload to; tarclone targets whatever backend it is.
TARCLONE_REMOTE=my-remote-destination

# ---- Common ----

# Path within the remote (unset = the remote's root).
TARCLONE_REMOTE_PATH=important-stuff-backups

# Keep the newest N archives on the remote; 0 = keep all.
TARCLONE_RETENTION_COUNT=10

# Read each upload back and compare sha256 before publishing.
TARCLONE_VERIFY_CHECKSUM=true

# ---- Optional (defaults shown) ----

# TARCLONE_ARCHIVE_PREFIX=important-stuff  # archive-name prefix (default: TARCLONE_SOURCE basename)
# TARCLONE_STAGING_DIR=/tmp                # where the archive is built; needs room for one full copy
# TARCLONE_LOCK_FILE=                      # single-instance lock path (default: under TARCLONE_STAGING_DIR)
# TARCLONE_COMPRESS_PROG=                  # alternate compressor, e.g. pigz; must exist (empty = gzip)

# rclone call tuning:
# TARCLONE_TIMEOUT=120s    # per-operation I/O timeout
# TARCLONE_CONTIMEOUT=30s  # connection timeout
# TARCLONE_RETRIES=2       # whole-operation retries
# TARCLONE_RCLONE_FLAGS=   # extra flags for every rclone call, e.g. --bwlimit 8M
# RCLONE_CONFIG=           # rclone's own config path; set if not at its default

# Quiesce hooks (generic shell; e.g. pause/resume an app around the read):
# TARCLONE_PRE_HOOK=   # runs before the archive
# TARCLONE_POST_HOOK=  # runs after it (always runs, even on failure)

# ---- Optional external heartbeat (dead-man's-switch) ----
# Requires the -http-client image variant (bundles curl). GET on success; the
# start/fail URLs are optional. For healthchecks.io, append /start and /fail.
# TARCLONE_PING_URL=https://hc-ping.com/<uuid>
# TARCLONE_PING_URL_START=https://hc-ping.com/<uuid>/start
# TARCLONE_PING_URL_FAILURE=https://hc-ping.com/<uuid>/fail
# TARCLONE_PING_TIMEOUT=10  # seconds allowed per ping
