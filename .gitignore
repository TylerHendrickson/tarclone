# Ignore all files; un-ignore directories for traversal (allowlist-strategy)
/**/*
!**/

# Except the following files...

# Boilerplate
!/.gitignore
!/LICENSE
!/README.md
!/SECURITY.md
!/CONTRIBUTING.md
!/CHANGELOG.md

# Editor config
!.editorconfig
!/.vscode/extensions.json
!/.vscode/settings.json

# Actual source files
!/Dockerfile
!/tarclone

# Security scanning
!/.trivyignore

# Tests
!/test/smoke.sh

# Example files
!/example/*

# CI/CD workflows
!.github/workflows/*.yml
!/.release-please-manifest.json
!/.release-please-config.json

# Renovate config
!/.github/renovate.json5
