{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    'docker:enableMajor',
    'docker:pinDigests',
    ':dependencyDashboard',
    ':semanticCommits',
    'helpers:pinGitHubActionDigests',
  ],
  schedule: ['before 4am'],
  // The root Dockerfile pins supercronic with a "# renovate:" hint before the
  // ARG. Renovate's shared presets only match docker/*/Dockerfile paths, so a
  // repo with a root Dockerfile needs its own matcher to bump SUPERCRONIC_VERSION.
  // (Renovate can't refresh the per-arch SUPERCRONIC_SHA1 pins — no datasource
  // yields release-asset checksums — so the update-supercronic-sha workflow
  // recomputes them on the PR as a committable suggestion; the checksum build
  // step fails loudly if a bump lands with stale pins.)
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: ['/(^|/)Dockerfile$/'],
      matchStrings: [
        '# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s+ARG \\S*_VERSION=(?<currentValue>\\S+)',
      ],
    },
  ],
  packageRules: [
    {
      // The example compose file self-references our own published image, pinned
      // to :latest on purpose (users are told to pin it themselves). It's not a
      // dependency to track, and Renovate's digest lookup of the not-yet-public
      // GHCR package 401s — surfacing as a "No docker auth found" repo warning.
      // Leave it alone.
      description: 'Ignore self-reference to our own GHCR image',
      matchDepNames: ['ghcr.io/tylerhendrickson/tarclone'],
      enabled: false,
    },
    {
      description: 'Bundle + automerge GitHub Actions non-major updates',
      matchManagers: ['github-actions'],
      matchUpdateTypes: ['digest', 'minor', 'patch'],
      groupName: 'github-actions',
      automerge: true,
    },
  ],
}
